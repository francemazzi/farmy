# ===========================================
# Farmy - Configurazione ambiente
# Copia questo file in .env.production e modifica i valori
# ===========================================

# --- Obbligatorio ---
# Chiave segreta per i token JWT (cambiala con una stringa casuale!)
JWT_SECRET=change-me-to-a-random-string

# Percorso database SQLite
DATABASE_URL=file:/app/data/farmy.db

# --- Opzionale ---
# API key OpenAI (per funzionalita' AI di importazione prodotti)
OPENAI_API_KEY=

# Token tunnel Cloudflare (solo se usi --profile tunnel-named)
# Ottienilo da: Cloudflare Zero Trust > Networks > Tunnels > Crea tunnel
CLOUDFLARE_TUNNEL_TOKEN=
